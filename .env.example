# Public app settings
NEXT_PUBLIC_MAIL_DOMAIN=mail.yourdomain.com
NEXT_PUBLIC_EMBED_PARENT_ORIGIN=https://your-frontend.com
NEXT_PUBLIC_DEMO_INBOUND_ENABLED=false

# Runtime
PORT=3000
HOSTNAME=0.0.0.0
NODE_ENV=production

# Mailbox behavior
MAILBOX_TTL_SECONDS=600
MAX_MESSAGES_PER_MAILBOX=50
MAX_ATTACHMENTS_PER_MESSAGE=0
MAX_INBOUND_BODY_BYTES=65536

# Security
INBOUND_API_KEY=replace-with-a-long-random-secret
ALLOWED_ORIGINS=https://your-frontend.com,https://yourdomain.com
GENERATE_RATE_LIMIT_PER_MINUTE=30
INBOUND_RATE_LIMIT_PER_MINUTE=120

# Production store
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
